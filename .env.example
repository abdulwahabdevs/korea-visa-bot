# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that are allowed to be admins
ADMIN_CHAT_IDS=123456789,987654321

# Password required to unlock bulk-check commands (/checkall, /export, /students)
# Leave blank to disable password protection (not recommended for production)
ADMIN_PASSWORD=your_secure_password_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# SQLite database path (relative to project root)
DB_PATH=data/visa_bot.db

# ── Security ───────────────────────────────────────────────────────────────────
# Secret key used to encrypt student PII (passport, name, DOB) at rest.
# Set this to any long random string. Example: openssl rand -hex 32
# WARNING: changing this after data is saved will make existing records unreadable.
SECRET_KEY=change_me_to_a_long_random_string

# Admin session TTL in hours (default: 24). Sessions older than this require re-login.
ADMIN_SESSION_TTL_HOURS=24

# Per-user cooldown between visa checks in seconds (default: 30).
USER_COOLDOWN_SECONDS=30

# ── Concurrency (Worker Pool) ──────────────────────────────────────────────────
# Number of parallel Chrome workers.
# Each worker = ~200 MB RAM + 1 Chrome process.
# Recommended values:
#   1 GB  RAM → CHROME_POOL_SIZE=2
#   2 GB  RAM → CHROME_POOL_SIZE=3   ← default
#   4 GB  RAM → CHROME_POOL_SIZE=5
#   8 GB  RAM → CHROME_POOL_SIZE=8
# Setting it too high will cause Chrome to crash (out of memory).
CHROME_POOL_SIZE=3

# Result cache TTL in seconds (default 300 = 5 minutes).
# Students who check the same passport within this window
# get an instant cached reply without hitting the portal.
CACHE_TTL_SECONDS=300


# when unauthorized user tries to login sees 
# the support admin profile to contact
SUPPORT_CHAT_ID=123456789

# Telethon to send suppord admin profile card when someone tried to access 
# login unauthorized to contact support admin
TELETHON_API_ID=12345678
TELETHON_API_HASH=abc123def456abc123def456
TELETHON_PHONE=+998901234567